{
  "name": "rippr",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.5",
  "scripts": {
    "build": "pnpm --filter @rippr/shared build && pnpm --filter @rippr/plugin build && cargo build --manifest-path helper/Cargo.toml --release",
    "build:plugin": "pnpm --filter @rippr/plugin build",
    "build:helper": "cargo build --manifest-path helper/Cargo.toml --release",
    "dev": "pnpm --filter @rippr/plugin dev",
    "dev:helper": "cargo run --manifest-path helper/Cargo.toml",
    "typecheck": "pnpm --filter @rippr/shared typecheck && pnpm --filter @rippr/plugin typecheck",
    "test": "pnpm typecheck && cargo test --manifest-path helper/Cargo.toml",
    "format:check": "cargo fmt --manifest-path helper/Cargo.toml -- --check",
    "lint": "cargo clippy --manifest-path helper/Cargo.toml --all-targets -- -D warnings",
    "package:stage": "node scripts/stage-package.mjs"
  }
}
